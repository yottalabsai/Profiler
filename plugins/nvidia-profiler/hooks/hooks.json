{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/notify-profile.js\"",
            "timeout": 5000
          }
        ],
        "description": "Prompt /analyze after profile.json is written",
        "id": "post:write:profile-json"
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/notify-optimizations.js\"",
            "timeout": 5000
          }
        ],
        "description": "Prompt /backend after optimizations.json is written",
        "id": "post:write:optimizations-json"
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/notify-optimized-py.js\"",
            "timeout": 5000
          }
        ],
        "description": "Prompt /validate after *_optimized.py is written",
        "id": "post:write:optimized-py"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/check-script-args.js\"",
            "timeout": 3000
          }
        ],
        "description": "Warn when operator-profiler map command has --script-args in wrong position",
        "id": "pre:bash:script-args-order"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"process.stdout.write('[profiler-plugin] Commands: /capture /analyze /propose /backend /validate /compare /report /optimize\\n')\"",
            "timeout": 3000
          }
        ],
        "description": "Announce available commands at session start",
        "id": "session:start:announce"
      }
    ]
  }
}
